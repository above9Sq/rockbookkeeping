---
import Image from '~/components/common/Image.astro';
import CertBookkeeper from '/src/assets/images/cert-bookkeeper.png';
import CertLevel1 from '/src/assets/images/cert-level1.png';

interface Props {
  bgColor?: string;
}

const { bgColor = '#ffffff' } = Astro.props;

const credentials = [
  'Intuit-Certified QuickBooks ProAdvisor',
  'Intuit-Trained Bookkeeper',
  'QuickBooks Online Specialist',
];
---

<section style={`background-color: ${bgColor}`}>
  <div class="max-w-[1600px] mx-auto px-6 xl:px-[120px] pt-4 pb-5 sm:py-7">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 max-w-3xl mx-auto">
      <div class="flex items-center gap-3 shrink-0">
        <Image
          src={CertBookkeeper}
          alt="Intuit Certified Bookkeeper badge"
          width={56}
          height={56}
          loading="lazy"
          decoding="async"
          class="h-14 w-14"
        />
        <Image
          src={CertLevel1}
          alt="Intuit Level 1 Certified Bookkeeper badge"
          width={56}
          height={56}
          loading="lazy"
          decoding="async"
          class="h-14 w-14"
        />
      </div>

      <div class="flex flex-col items-center gap-1 sm:flex-row sm:flex-wrap sm:gap-x-3.5 sm:gap-y-1">
        {
          credentials.map((cred, index) => (
            <>
              <span class="text-[0.9375rem] font-medium text-gray-600">{cred}</span>
              {index < credentials.length - 1 && (
                <span class="hidden sm:inline text-gray-300 select-none" aria-hidden="true">•</span>
              )}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>
