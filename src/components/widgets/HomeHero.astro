---
import Hero from './Hero.astro';
import heroHeadshot from '~/assets/images/hero-headshot-square.png';
import { theme } from '~/theme';

const hero = {
  headline: "Know your numbers. Every single month.",
  subheadline: 'Reliable monthly bookkeeping (and cleanup when needed) for small business owners who want clarity, not chaos.',
  primaryCta: { kind: 'cal', label: 'Book a call with Josh', class: 'btn-pop' },
  secondaryCta: { kind: 'modal', variant: 'dark', label: 'Send Josh a quick note' },
  image: {
    src: heroHeadshot,
    alt: 'Josh Cesana, Rock Bookkeeping',
    width: 385,
    height: 341,
    loading: 'eager',
    fetchpriority: 'high',
  },
  showSignature: true,
  bgColor: theme.heroBg,
};
---

<Hero {...hero} />
